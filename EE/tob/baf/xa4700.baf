//{ Simulacra Monitoring
IF
	HPLT("xanarzu7", 10)
THEN
	RESPONSE #100
		SetGlobal("XA_LC_Narzu7Killed", "MYAREA", 1)
		SetGlobal("XA_LC_Collapse", "MYAREA", 1)
		CreateVisualEffectObject("1WDCMDAM", "xanarzu7")
		ActionOverride("xanarzu7", DropInventory())
		ActionOverride("xanarzu7", DestroySelf())
		Continue()
END


IF
	Global("XA_LC_CSStart", "MYAREA", 1)
THEN
	RESPONSE #100
		SetGlobal("XA_LC_CSStart", "MYAREA", 0)
		StartCutSceneMode()
		StartCutScene("XA470001")
END

//{ Collapse Messaging
IF
	InParty("XACORWIN")
	GlobalLT("XA_LC_TowerCollapseCorwin", "MYAREA", 1)
	Global("XA_LC_CollapseTimerSet", "MYAREA", 1)
THEN
	RESPONSE #100
		SetGlobal("XA_LC_TowerCollapseCorwin", "MYAREA", 1)
		DisplayStringHead("XACORWIN", @4)
END

IF

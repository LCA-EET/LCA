IF
	True()
THEN
	RESPONSE #100
		CutSceneId(Player1)
		FadeToColor([20.0],0)
		Wait(2)
		ActionOverride("xasprspy", DestroySelf())
		ActionOverride("xacorspr", DestroySelf())
		Wait(1)
		SetGlobal("XA_LC_Journal_Spring", "GLOBAL", 1)
		RestorePartyLocations()
		FadeFromColor([20.0], 0)
		Wait(3)
		EndCutSceneMode()
		UnhideGUI()
END